# ============================================================
# 税率政策工具 — 后端环境变量
# 复制为 .env 后填写实际值
# ============================================================

# ==================== 通用 ====================
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
JWT_EXPIRY=3600

# ==================== 密钥（必须修改） ====================
# 生成方式: openssl rand -hex 64
POSTGRES_PASSWORD=your_postgres_password_here
JWT_SECRET=your_jwt_secret_at_least_32_chars_here

# 生成方式: 见 scripts/generate-keys.sh
ANON_KEY=your_anon_key_here
SERVICE_ROLE_KEY=your_service_role_key_here

# ==================== 腾讯云 SMS ====================
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SIGN_NAME=税率政策工具
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_SDK_APP_ID=
# 开发环境可设为 true 跳过短信验证
SMS_AUTOCONFIRM=false

# ==================== 微信支付 ====================
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY_V3=
WECHAT_SERIAL_NO=
# 证书文件放在 certs/wechat/ 目录

# ==================== 支付宝 ====================
ALIPAY_APP_ID=
# 证书文件放在 certs/alipay/ 目录

# ==================== 端口 ====================
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
STUDIO_PORT=3001

# ==================== URI 白名单 ====================
URI_ALLOW_LIST=https://pay.tarifftool.com/**
